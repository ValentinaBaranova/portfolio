---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative pt-24 pb-12 md:pt-32 md:pb-20 overflow-hidden">
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex flex-col-reverse md:flex-row gap-12 items-center">
      <div class="flex-1 max-w-3xl text-center md:text-left">
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-slate-900 mb-6 leading-[1.1] text-balance">
          {t('hero.headline')}
        </h1>
        <p class="text-lg md:text-xl text-slate-600 mb-10 leading-relaxed">
          {t('hero.subheadline')}
        </p>
        
        <div class="flex flex-wrap justify-center md:justify-start gap-4 mb-12">
          <a href="#projects" class="px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg transition-all shadow-lg shadow-blue-200 hover:shadow-blue-300 whitespace-nowrap">
            {t('hero.cta.projects')}
          </a>
          <a href="#contact" class="px-8 py-4 bg-white border border-slate-200 hover:border-slate-300 text-slate-700 font-bold rounded-lg transition-all whitespace-nowrap">
            {t('hero.cta.contact')}
          </a>
          <a 
            href="/Valentina Baranova - CV - Senior Backend Engineer.pdf" 
            download="Valentina Baranova - CV.pdf"
            class="px-8 py-4 bg-slate-50 border border-slate-200 hover:border-slate-300 text-slate-600 font-bold rounded-lg transition-all hidden md:flex items-center gap-2 whitespace-nowrap"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="hidden md:block w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            {t('hero.cta.cv')}
          </a>
        </div>
  
        <div class="space-y-3">
          <div class="flex items-center justify-center md:justify-start gap-3 text-sm font-medium text-slate-500">
            <span class="w-2 h-2 rounded-full bg-blue-500 shrink-0"></span>
            {t('hero.tech')}
          </div>
          <div class="flex items-center justify-center md:justify-start gap-3 text-sm font-medium text-slate-500">
            <span class="w-2 h-2 rounded-full bg-slate-300 shrink-0"></span>
            <span>
              <span class="hidden md:inline">{t('hero.city')} · </span>{t('hero.timezone')} · {t('hero.languages')}
            </span>
          </div>
        </div>
      </div>

      <div class="w-48 h-48 md:w-80 md:h-80 shrink-0 relative">
        <div class="absolute inset-0 bg-blue-600 rounded-2xl rotate-6 -z-10 opacity-10"></div>
        <img 
          src="/avatar1.jpg" 
          alt={t('site.alt.profile')} 
          class="w-full h-full object-cover object-[center_43%] rounded-2xl shadow-xl border-4 border-white scale-95"
        />
      </div>
    </div>
  </div>
  
  <div class="absolute -top-24 -right-24 w-96 h-96 bg-blue-50 rounded-full blur-3xl -z-10 opacity-50"></div>
  <div class="absolute top-1/2 -left-24 w-72 h-72 bg-indigo-50 rounded-full blur-3xl -z-10 opacity-50"></div>
</section>
