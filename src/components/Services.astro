---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const services = [
  {
    title: t('services.1.title'),
    description: t('services.1.desc'),
    items: t('services.1.items') as unknown as string[],
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01'
  },
  {
    title: t('services.2.title'),
    description: t('services.2.desc'),
    items: t('services.2.items') as unknown as string[],
    icon: 'M13 10V3L4 14h7v7l9-11h-7z'
  },
  {
    title: t('services.3.title'),
    description: t('services.3.desc'),
    items: t('services.3.items') as unknown as string[],
    icon: 'M4 7v10c0 2.21 4.48 4 10 4s10-1.79 10-4V7M4 7c0 2.21 4.48 4 10 4s10-1.79 10-4M4 7c0-2.21 4.48-4 10-4s10 1.79 10 4m0 5c0 2.21-4.48 4-10 4S4 14.21 4 12'
  },
  {
    title: t('services.4.title'),
    description: t('services.4.desc'),
    items: t('services.4.items') as unknown as string[],
    icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0012 18.75c-1.03 0-1.9.4-2.593 1.02l-.547.547z'
  }
];
---

<section id="services" class="py-16 md:py-24">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 mb-4">{t('services.title')}</h2>
      <div class="h-1 w-12 bg-blue-600 rounded-full mx-auto"></div>
    </div>
    
    <div class="grid md:grid-cols-2 gap-8">
      {services.map((service) => (
        <div class="p-8 border border-slate-100 rounded-2xl bg-white hover:border-blue-100 hover:shadow-xl hover:shadow-blue-50/50 transition-all group">
          <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={service.icon} />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">{service.title}</h3>
          <p class="text-slate-600 mb-6 leading-relaxed">
            {service.description}
          </p>
          <ul class="space-y-2">
            {service.items.map((item) => (
              <li class="flex items-center gap-2 text-sm text-slate-500">
                <span class="w-1 h-1 rounded-full bg-blue-400"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
