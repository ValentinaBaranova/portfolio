---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const techGroups = [
  {
    title: t('tech.backend'),
    items: ['Kotlin', 'Java', 'Spring Boot', 'REST APIs', 'Kafka', 'RabbitMQ']
  },
  {
    title: t('tech.frontend'),
    items: ['Next.js', 'React', 'Astro', 'TypeScript']
  },
  {
    title: t('tech.databases'),
    items: ['PostgreSQL', 'MongoDB', 'Redis']
  },
  {
    title: t('tech.cloud'),
    items: ['Docker', 'Kubernetes', 'AWS', 'Cloudflare Pages']
  },
  {
    title: t('tech.ai'),
    items: ['OpenAI API', 'AI-assisted workflows', 'automation pipelines']
  }
];
---

<section id="tech" class="py-16 md:py-24 bg-slate-50">
  <div class="max-w-5xl mx-auto px-6">
    <div class="mb-12">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 mb-4">{t('tech.title')}</h2>
      <div class="h-1 w-12 bg-blue-600 rounded-full"></div>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8">
      {techGroups.map((group) => (
        <div>
          <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-6">{group.title}</h3>
          <ul class="space-y-3">
            {group.items.map((item) => (
              <li class="text-slate-700 font-medium">{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
