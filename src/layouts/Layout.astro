---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { title, description } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const siteTitle = title || t('site.title');
const siteDescription = description || t('site.description');
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{siteTitle}</title>
		<meta name="description" content={siteDescription} />
		<meta name="keywords" content={t('site.keywords')} />
	</head>
	<body class="bg-white text-slate-900 selection:bg-blue-100 selection:text-blue-900 antialiased">
		<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
			<nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
				<a href={lang === 'en' ? '/' : `/${lang}/`} class="font-bold text-xl tracking-tight">
					Valentina Baranova
				</a>
				<div class="flex items-center gap-6">
					<div class="hidden md:flex items-center gap-6 text-sm font-medium text-slate-600">
						<a href="#projects" class="hover:text-blue-600 transition-colors">
							{t('nav.projects')}
						</a>
						<a href="#contact" class="hover:text-blue-600 transition-colors">
							{t('nav.contact')}
						</a>
					</div>
					<div class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider">
						<a 
							href="/" 
							class={lang === 'en' ? 'text-blue-600' : 'text-slate-400 hover:text-slate-600 transition-colors'}
						>
							EN
						</a>
						<span class="text-slate-200">|</span>
						<a 
							href="/es/" 
							class={lang === 'es' ? 'text-blue-600' : 'text-slate-400 hover:text-slate-600 transition-colors'}
						>
							ES
						</a>
					</div>
				</div>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer class="bg-slate-50 border-t border-slate-100 py-12">
			<div class="max-w-5xl mx-auto px-6 text-center">
				<p class="text-slate-900 font-bold mb-2">
					&copy; {new Date().getFullYear()} Valentina Baranova · Buenos Aires, Argentina
				</p>
				<p class="text-slate-500 text-sm">
					Freelance web app & automation developer · English · Spanish · Russian
				</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: smooth;
	}
</style>
